{
  "global": {
    "files": "/**/*.abap",
    "skip": "/node_modules/"
  },
  "dependencies": [
    {
      "url": "https://raw.githubusercontent.com/SAP/styleguides/main/clean-abap/CleanABAP.json"
    }
  ],
  "syntax": {
    "version": "v740sp02",
    "error": ["syntax_error"]
  },
  "rules": {
    "indentation": {
      "allow_chain_declaration": true
    },
    "line_length": {
      "maximum": 120
    },
    "naming": {
      "allow_underscore": true
    }
  }
}
