{
  "global": {
    "files": "/**/*.{abap,clas.abap,prog.abap,intf.abap,func.abap,fugr.abap}",
    "exclude": [],
    "skipGeneratedGatewayClasses": true,
    "skipGeneratedPersistentClasses": true,
    "skipGeneratedFunctionGroups": true,
    "useApackDependencies": false
  },
  "dependencies": [],
  "syntax": {
    "version": "v750",
    "errorNamespace": "^(Z|Y|LCL_|LCX_|LIF_|LTY_)",
    "globalConstants": [],
    "globalMacros": []
  },
  "rules": {
    "check_syntax": true,
    "parser_error": true,
    "cyclomatic_complexity": {
      "exclude": [],
      "severity": "Warning",
      "max": 20
    },
    "method_length": {
      "exclude": [],
      "severity": "Warning",
      "statements": 100,
      "ignoreTestClasses": true,
      "errorWhenEmpty": false
    },
    "line_length": {
      "exclude": [],
      "severity": "Warning",
      "length": 200
    },
    "sequential_blank": {
      "exclude": [],
      "severity": "Warning",
      "lines": 3
    },
    "unused_variables": {
      "exclude": [],
      "severity": "Warning"
    },
    "unreachable_code": {
      "exclude": [],
      "severity": "Error"
    },
    "uncaught_exception": {
      "exclude": [],
      "severity": "Warning"
    },
    "try_without_catch": {
      "exclude": [],
      "severity": "Warning"
    },
    "unnecessary_return": {
      "exclude": [],
      "severity": "Warning"
    },
    "select_add_order_by": {
      "exclude": [],
      "severity": "Warning"
    },
    "prefer_inline": {
      "exclude": [],
      "severity": "Warning"
    },
    "prefer_corresponding": {
      "exclude": [],
      "severity": "Warning"
    },
    "no_aliases": {
      "exclude": [],
      "severity": "Warning"
    },
    "empty_statement": {
      "exclude": [],
      "severity": "Warning"
    },
    "exporting": {
      "exclude": [],
      "severity": "Warning"
    },
    "use_line_exists": {
      "exclude": [],
      "severity": "Warning"
    },
    "when_others_last": {
      "exclude": [],
      "severity": "Error"
    },
    "names_no_dash": {
      "exclude": [],
      "severity": "Warning"
    },
    "prefer_is_not": {
      "exclude": [],
      "severity": "Warning"
    },
    "identical_form_names": {
      "exclude": [],
      "severity": "Error"
    },
    "if_in_loop_check": {
      "exclude": [],
      "severity": "Warning"
    }
  }
}
